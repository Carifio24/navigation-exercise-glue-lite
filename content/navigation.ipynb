   "source": [
    "# Scatter viewer\n",
    "\n",
    "teams_scatter = app.new_data_viewer(BqplotScatterView, data=data)\n",
    "teams_scatter.state.x_att = data.id[\"EndLong\"]\n",
    "teams_scatter.state.y_att = data.id[\"EndLat\"]\n",
    "for color_data in color_datasets:\n",
    "    teams_scatter.add_data(color_data)\n",
    "    layer = layer_for_data(teams_scatter, color_data)\n",
    "    layer.state.fill = False\n",
    "    layer.state.size = 6\n",
    "    layer.state.line_visible = True\n",
    "    layer.state.linewidth = 1\n",
    "    layer.state.linestyle = \"solid\"\n",
    "\n",
    "for layer in teams_scatter.layers:\n",
    "    if layer.layer.label == \"Common End\":\n",
    "        layer.state.size = 12\n",
    "        layer.state.alpha = 1"
   ]
  },
