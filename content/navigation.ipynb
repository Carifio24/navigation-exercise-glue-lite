   "source": [
    "from os.path import join\n",
    "import sys\n",
    "from glue.core.link_helpers import LinkSame\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "from glue.core import Data\n",
    "from glue.core.subset import AndState, CategorySubsetState, RangeSubsetState\n",
    "\n",
    "from glue_jupyter import jglue\n",
    "from glue_jupyter.bqplot.histogram import BqplotHistogramView\n",
    "from glue_jupyter.bqplot.scatter import BqplotScatterView\n",
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ed9e6b37",
   "metadata": {},
   "outputs": [],
   "source": [
    "from os.path import splitext\n",
    "import string\n",
    "\n",
    "from glue.core.link_helpers import LinkSame\n",
    "\n",
    "\n",
    "def printable_string(s):\n",
    "    return \"\".join(filter(lambda x: x in string.printable, s))\n",
    "\n",
    "\n",
    "# Some of the components have non-printable characters in their names\n",
    "# when loaded from the CSV, which makes them hard to grab later.\n",
    "# So we strip any non-printable characters from the component names\n",
    "def clean_component_names(data):\n",
    "    for component in data.components:\n",
    "        component.label = printable_string(component.label)\n",
    "\n",
    "\n",
    "def layer_for_data(viewer, data):\n",
    "    for layer in viewer.layers:\n",
    "        if layer.layer is data:\n",
    "            return layer\n",
    "    return None\n",
    "\n",
    "\n",
    "# TODO: This is not very robust, just to get things working\n",
    "def color_for_path(filepath, colors):\n",
    "    name, ext = splitext(filepath)\n",
    "    if ext != \".csv\":\n",
    "        return None \n",
    "    for color in colors:\n",
    "        color = str(color)\n",
    "        if color.lower() in name.lower():\n",
    "            return color\n",
    "\n",
    "    return None"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 61,
   "id": "c535c38a",
   "metadata": {},
   "outputs": [],
   "source": [
    "def color_filename(color):\n",
    "    return f\"GenEd 1112 {color.upper()}.csv\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 62,
   "id": "21bf55d3",
   "metadata": {},
   "outputs": [],
   "source": [
    "app = jglue()\n",
    "dc = app.data_collection"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 63,
   "id": "aaec3141",
   "metadata": {},
   "outputs": [],
   "source": [
    "data_filepath = \"2024_Nav_edited.csv\"\n",
    "color_dir = \"color files\"\n",
    "\n",
    "# Load in the data\n",
    "data = app.load_data(data_filepath)\n",
    "clean_component_names(data)\n",
    "data.style.color = \"#f1e7ed\"\n",
    "colors = np.unique(data[\"Color\"])\n",
    "color_datasets = []\n",
    "for color in colors:\n",
    "    name = color_filename(color)\n",
    "    path = join(color_dir, name)\n",
    "    color_data = app.load_data(path)\n",
    "    color_data.style.color = color\n",
    "    color_data.style.alpha = 1\n",
    "    color_data.style.markersize = 20\n",
    "    clean_component_names(color_data)\n",
    "    color_datasets.append(color_data)\n",
    "    dc.add_link(LinkSame(data.id[\"EndLat\"], color_data.id[\"Latitude\"]))\n",
    "    dc.add_link(LinkSame(data.id[\"EndLong\"], color_data.id[\"Longitude\"]))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 64,
   "id": "622fd55d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Make team subsets\n",
    "for color, code in zip(colors, colors.codes):\n",
    "    dc.new_subset_group(label=color,\n",
    "                        subset_state=CategorySubsetState(att=data.id[\"Color\"], categories=[code]),\n",
    "                        color=color,\n",
    "                        alpha=1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 65,
   "id": "dc67f97b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Make the \"1-1\" data\n",
    "# and link it to our main data set\n",
    "one_to_one = Data(label=\"one-to-one\", Uncertainty=[0, 1000], End=[0, 1000])\n",
    "dc.append(one_to_one)\n",
    "dc.add_link(LinkSame(data.id[\"UNCERTAINTY\"], one_to_one.id[\"Uncertainty\"]))\n",
    "dc.add_link(LinkSame(data.id[\"End_off_feet\"], one_to_one.id[\"End\"]))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 66,
   "id": "ecef9c9b",
   "metadata": {},
   "outputs": [],
   "source": [
    " # Find the winner(s) and create a subset\n",
    "min_distance = min(data[\"End_off_feet\"])\n",
    "winner_sg = dc.new_subset_group(label=\"Winners\",\n",
    "                                subset_state=RangeSubsetState(lo=min_distance, hi=min_distance, att=data.id[\"End_off_feet\"]),\n",
    "                                color=\"Purple\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 67,
   "id": "5e354ef6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Make a subset for the correct end\n",
    "color_data = color_datasets[0]\n",
    "endpoint_mask = color_data[\"Name\"] == \"Common End Point\"\n",
    "lat = color_data[\"Latitude\"][endpoint_mask][0]\n",
    "lon = color_data[\"Longitude\"][endpoint_mask][0]\n",
    "lat_ss = RangeSubsetState(lo=lat, hi=lat, att=data.id[\"EndLat\"])\n",
    "lon_ss = RangeSubsetState(lo=lon, hi=lon, att=data.id[\"EndLong\"])\n",
    "endpoint_sg = dc.new_subset_group(label=\"Common End\",\n",
    "                                    subset_state=AndState(lat_ss, lon_ss),\n",
    "                                    color=\"Red\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 77,
   "id": "ab755822",
